# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/docxpress
# OR for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/docxpress?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d

# Google Sign-In (OAuth Web Client ID from Google Cloud/Firebase)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# CORS Configuration
CORS_ORIGIN=*
